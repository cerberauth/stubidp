{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "stubidp",
  "main": "src/worker.ts",
  "compatibility_date": "2026-05-14",
  "compatibility_flags": ["nodejs_compat"],
  "tsconfig": "tsconfig.worker.json",
  "build": {
    "command": "npm run build"
  },
  "workers_dev": false,
  "preview_urls": false,
  "routes": [
    {
      "pattern": "stubidp.cerberauth.com",
      "custom_domain": true
    }
  ],
  "alias": {
    "bun:sqlite": "./src/db/bun-sqlite-stub"
  },
  "assets": {
    "directory": "./public"
  },
  "vars": {
    "STUBIDP_HTTPS_REDIRECT": "true",
    "STUBIDP_ISSUER": "https://stubidp.cerberauth.com",
    "STUBIDP_LOG_LEVEL": "warn",
    "STUBIDP_ENABLE_REGISTRATION": "true"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "stubidp-db",
      "database_id": "",
      "migrations_dir": "migrations/sqlite"
    }
  ]
}
