# Server Configuration
STUBIDP_PORT=8484
STUBIDP_LOG_LEVEL=info

# OIDC Configuration
STUBIDP_ISSUER=http://localhost:8484
STUBIDP_CLIENT_ID=my-client
STUBIDP_CLIENT_SECRET=my-secret
STUBIDP_REDIRECT_URI=http://localhost:3001/callback
# STUBIDP_JWKS_FILE=./jwks.json

# Rate Limiting (optional)
# STUBIDP_RATE_LIMIT_WINDOW_MS=900000
# STUBIDP_RATE_LIMIT_MAX=100
# STUBIDP_RATE_LIMIT_DISABLED=false

# Database Configuration (optional — defaults to in-memory)
# Use 'postgresql' or 'sqlite'
# STUBIDP_DATABASE_DIALECT=postgresql

# PostgreSQL connection string
# STUBIDP_DATABASE_URL=postgresql://user:password@localhost:5432/stubidp

# SQLite alternative
# STUBIDP_DATABASE_DIALECT=sqlite
# STUBIDP_DATABASE_URL=./data/stubidp.db
