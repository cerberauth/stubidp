# Server Configuration
PORT=3000
LOG_LEVEL=info

# OIDC Configuration
OIDC_ISSUER=http://localhost:3000
OIDC_CLIENT_ID=my-client
OIDC_CLIENT_SECRET=my-secret
OIDC_REDIRECT_URI=http://localhost:3001/callback
# OIDC_JWKS_FILE=./jwks.json

# Database Configuration (optional — defaults to in-memory)
# Use 'postgresql' or 'sqlite'
DATABASE_DIALECT=postgresql

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/stubidp

# SQLite alternative (uncomment and set DATABASE_DIALECT=sqlite)
# DATABASE_DIALECT=sqlite
# DATABASE_URL=./data/stubidp.db
