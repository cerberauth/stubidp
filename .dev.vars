# Local Worker development variables for `wrangler dev`.
# Copy this file to .dev.vars and edit as needed.

# OIDC_ISSUER is optional — when omitted the worker derives it from the
# incoming request URL (e.g. http://localhost:8787). Override it here if
# your local setup uses a different base URL or a tunnel (e.g. ngrok).
OIDC_ISSUER=http://localhost:8787

# Override the default client credentials from wrangler.json if needed.
# OIDC_CLIENT_ID=dev-client
# OIDC_CLIENT_SECRET=dev-secret
# OIDC_REDIRECT_URI=http://localhost:3000/callback
