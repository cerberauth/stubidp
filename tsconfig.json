{
  "compilerOptions": {
    "target": "es2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "rootDir": "src",
    "outDir": "build",
    "declaration": true,
    "sourceMap": true,
    "types": ["@cloudflare/workers-types"],
    "lib": ["es2022", "dom"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
