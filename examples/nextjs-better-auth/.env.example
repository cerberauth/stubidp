# Better Auth secret - generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=your-secret-here

# URL of this Next.js app
BETTER_AUTH_URL=http://localhost:3001

# stubidp configuration
# Run stubidp with: npx @cerberauth/stubidp --clientId web-app --clientSecret web-app-secret --redirectUri http://localhost:3001/api/auth/callback/stubidp
STUBIDP_CLIENT_ID=web-app
STUBIDP_CLIENT_SECRET=web-app-secret
STUBIDP_ISSUER=http://localhost:8484

# Exposed to the browser
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3001
